{
  "name": "seoul-openapi-mcp",
  "version": "2026.426.0",
  "description": "MCP server for Seoul Open Data OpenAPI services.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "keywords": [
    "mcp",
    "seoul",
    "openapi",
    "seoul-open-data"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ludens/seoul-openapi-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ludens/seoul-openapi-mcp/issues"
  },
  "homepage": "https://github.com/ludens/seoul-openapi-mcp#readme",
  "bin": {
    "seoul-openapi-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm check && pnpm test && pnpm build",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.0.14"
  }
}
